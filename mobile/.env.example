# Expo public variables are bundled into the mobile app.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Google Maps JavaScript API is used inside React Native WebView.
EXPO_PUBLIC_GOOGLE_MAPS_JAVASCRIPT_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_MAP_ID=
EXPO_PUBLIC_GOOGLE_MAPS_WEBVIEW_BASE_URL=https://hotplace.local
EXPO_PUBLIC_GOOGLE_DIRECTIONS_API_KEY=

# Native build identifiers
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.pinsnap.archive
EXPO_PUBLIC_ANDROID_PACKAGE=com.pinsnap.archive

# Firebase client config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# TAGO bus location
EXPO_PUBLIC_TAGO_BUS_SERVICE_KEY=
EXPO_PUBLIC_TAGO_BUS_CITY_CODE=
EXPO_PUBLIC_TAGO_BUS_ROUTE_ID=
EXPO_PUBLIC_TAGO_BUS_POLL_MS=20000
