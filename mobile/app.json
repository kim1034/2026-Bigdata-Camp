{
  "expo": {
    "name": "PinSnap Archive",
    "slug": "pinsnap-archive",
    "scheme": "pinsnaparchive",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F8FA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.pinsnap.archive",
      "supportsTablet": true
    },
    "android": {
      "package": "com.pinsnap.archive",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#F7F8FA"
      }
    }
  }
}
