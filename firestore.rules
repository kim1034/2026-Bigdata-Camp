rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }

    match /users/{userId}/friends/{friendUserId} {
      allow read, write: if true;
    }

    match /users/{userId}/shareInbox/{shareId} {
      allow read, write: if true;
    }

    match /friendRequests/{requestId} {
      allow read, write: if true;
    }

    match /sharedItems/{shareId} {
      allow read, write: if true;
    }

    match /workspaces/{workspaceId}/places/{placeId} {
      allow read, write: if true;
    }

    match /workspaces/{workspaceId}/collections/{collectionId} {
      allow read, write: if true;
    }

    match /workspaces/{workspaceId}/routes/{routeId} {
      allow read, write: if true;
    }

    match /workspaces/{workspaceId}/itineraries/{itineraryId} {
      allow read, write: if true;
    }

    match /workspaces/{workspaceId}/placeReviews/{placeId}/reviews/{reviewId} {
      allow read, write: if true;
    }
  }
}
